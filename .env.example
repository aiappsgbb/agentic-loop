# Copy to `.env` and fill in. `.env` is gitignored.

# EasyAuth client id for the agentic-loop-site SWA (used by deploy.ps1).
VITE_AZURE_CLIENT_ID=

# Same-origin mount path the persona builder + Kratos launcher deep-link into.
# In production this is served by Front Door (see infra/README.md). Default: /kratos
VITE_KRATOS_BASE=/kratos

# Local dev only — point at a standalone Kratos instance (e.g. http://localhost:3000).
# Persona/prompt deep-links work cross-origin; the sessionStorage import relay
# requires same-origin and only works behind Front Door. Leave unset in production.
# VITE_KRATOS_STANDALONE_URL=
